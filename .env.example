# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SESSION_SECRET: Required for signing secure portal session cookies.
SESSION_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_SECRET"

# PORT: Internal server port for production platforms such as Fly.io.
PORT="8080"

# AUTH_PORT: Optional server port for the auth API in local development.
AUTH_PORT="3001"

# DATABASE_PATH: SQLite location. Use /data/portal.sqlite on Fly.io with a mounted volume.
DATABASE_PATH="data/portal.sqlite"
